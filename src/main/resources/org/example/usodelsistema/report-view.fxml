<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.TableColumn?>
<?import javafx.scene.control.TableView?>
<?import javafx.scene.layout.VBox?>
<?import javafx.scene.text.Font?>

<VBox alignment="CENTER" spacing="15.0" xmlns:fx="http://javafx.com/fxml"
      fx:controller="org.example.usodelsistema.controllers.ReportController"
      stylesheets="@styles.css" styleClass="root">
    <padding>
        <Insets bottom="20.0" left="20.0" right="20.0" top="20.0"/>
    </padding>

    <Label text="Historial de Procesos Finalizados" styleClass="header-label"/>

    <TableView fx:id="tablaHistorial" prefHeight="300.0" prefWidth="600.0">
        <columns>
            <TableColumn fx:id="colNombre" text="Nombre" prefWidth="100.0" />
            <TableColumn fx:id="colTamano" text="Tamaño" prefWidth="80.0" />
            <TableColumn fx:id="colLlegada" text="Hora Llegada" prefWidth="120.0" />
            <TableColumn fx:id="colSalida" text="Hora Salida" prefWidth="120.0" />
            <TableColumn fx:id="colEspera" text="T. Espera (s)" prefWidth="90.0" />
            <TableColumn fx:id="colSistema" text="T. Sistema (s)" prefWidth="90.0" />
        </columns>
    </TableView>

    <Button text="Cerrar" onAction="#onCloseButtonClick" styleClass="button"/>
</VBox>
